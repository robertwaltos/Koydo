    "--type-sm": "0.81rem",
    "--type-md": "0.92rem",
    "--type-lg": "1rem"
  },
  "dark_mode": {
    "--background": "#0f172a",
    "--foreground": "#e5edf8",
    "--surface": "#111827",
    "--surface-muted": "#1f2937",
    "--surface-strong": "#273449",
    "--border": "#2d3a50",
    "--accent": "#4f729c",
    "--accent-subtle": "#1a2a3f",
    "--color-primary": "#4f729c",
    "--success": "#3f7f64",
    "--warn": "#c79b63",
    "--danger": "#d95f52"
