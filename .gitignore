# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright test results (all variants)
/e2e/test-results*/
/e2e/report/
/playwright-report/
/blob-report/
/test-results/

# next.js
/.next/
/.next-smoke*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.devserver.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.pyc

# AI-generated media assets (produced at runtime by overnight-media-runner.mjs / process-media-jobs.mjs)
# Large raw-generation folder is excluded, but specific production assets used
# by the live site are whitelisted below so Vercel receives them.
public/generated-images/
!public/generated-images/hero-light-03.png
!public/generated-images/bg-day-v1.jpg
!public/generated-images/hero-light-02.jpg
!public/generated-images/hero-light-07-v3.jpg

# Compiled catalog JSON (generated by scripts/compile-catalog-json.mjs at prebuild time)
src/lib/modules/generated/catalog-data.json

# Backup files
*.bak*

# Local accessibility audit output
a11y-*.txt

# Storybook compiled output
/storybook-static/

# Debug logs
debug-storybook.log

# Raw source assets (large originals kept locally)
public/Grok Assets/

.env*.local

# Claude/agent temp files
tmpclaude*
tmp_resume*
consensus.docx
cleanup.md
object_info.json
nul
do_commit.ps1
.git-acl-backup.txt

# Temp analysis/audit files
_*.txt
.tmp-*
.preflight-*.json

# All log files (catch-all)
*.log

# Data assets (large datasets, models, open-source-games)
data/

# Old/duplicate project workspace (has its own repo)
eduforge-web/

# Python type cache
.mypy_cache/

# Large intermediate data files in scripts (generated, not source)
scripts/_chapter_data*.json
scripts/epub-catalog.json
scripts/epub-educational-picks.json

# Logs
logs/

.next-stale*/

# Dev artifacts in public/ (reports, manifests, generated media)
public/LESSON-MEDIA-PROMPT-PACK.json
public/CURRICULUM-STATE-FOR-EXTERNAL-AGENTS.json
public/translations/es/_state.json
public/GROK-IMAGE-MANIFEST-NORMALIZED.json
public/games-factory/
public/media/generated/
public/*-REPORT*.json
public/*-REPORT*.md
public/*-AUDIT*.json
public/*-AUDIT*.md
public/*-ENRICHMENT-*.json
public/*-COVERAGE-*.json
public/*-STATE-*.json
public/*-QUEUE*.json
public/*-MANIFEST*.json
!public/manifest.json
!public/audio/greetings/manifest.json
public/*-PLAN*.json
public/*-BACKLOG*.json
public/*-SIGNOFF*.json
public/AUDIOBOOK-*.json
public/BACKGROUND-LAUNCH-*.json
public/BACKGROUND-LAUNCH-*.md
